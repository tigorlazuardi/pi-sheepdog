{
  "name": "pi-sheepdog",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Pi extension that detects provider rate-limit/quota errors and schedules a follow-up message to resume once the cooldown passes.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "rate-limit",
    "wakeup",
    "sheepdog"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tigorlazuardi/pi-sheepdog.git"
  },
  "files": [
    "extensions",
    "README.md",
    "docs/astro.config.mjs",
    "docs/package.json",
    "docs/package-lock.json",
    "docs/tsconfig.json",
    "docs/src"
  ],
  "scripts": {
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "self-check": "node ./scripts/self-check.mjs",
    "check": "npm run docs:build && npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
